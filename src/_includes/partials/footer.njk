<footer class="bg-dark py-5 mt-auto">
    <div class="container px-5">
        <div class="row gy-4">
            <div class="col-lg-6">
                <div class="fw-bold text-white mb-2">{{ site.copyright }}</div>
                <div class="text-white-50 small">{{ site.address }}</div>
            </div>
            <div class="col-lg-3">
                <div class="text-white fw-semibold mb-2">Contacto</div>
                <div class="text-white-50 small mb-1">
                    <i class="bi bi-envelope me-1"></i>
                    <a class="text-white-50 text-decoration-none" href="mailto:{{ site.email }}">{{ site.email }}</a>
                </div>
                <div class="text-white-50 small">
                    <i class="bi bi-telephone me-1"></i>
                    <a class="text-white-50 text-decoration-none" href="tel:{{ site.phone }}">{{ site.phone }}</a>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="text-white fw-semibold mb-2">Páginas</div>
                <ul class="list-unstyled mb-0">
                    {% for link in nav.links %}
                    <li class="mb-1">
                        <a class="text-white-50 text-decoration-none small" href="{{ link.url }}">{{ link.label }}</a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        <hr class="border-secondary mt-4 mb-3" />
        <div class="text-white-50 small text-center">
            &copy; {{ site.copyright }} &middot; Soporte: <a class="text-white-50" href="mailto:{{ site.support_email }}">{{ site.support_email }}</a>
        </div>
    </div>
</footer>
