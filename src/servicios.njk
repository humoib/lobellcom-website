---
layout: layouts/base.njk
title: Servicios
permalink: /servicios/
---

<!-- Header -->
<header class="bg-dark text-white py-5">
  <div class="container px-5">
    <h1 class="fw-bold mb-1">Servicios ofrecidos</h1>
    <p class="text-white-50 lead mb-0">Aquí puedes revisar todos nuestros servicios.</p>
  </div>
</header>

<!-- Service nav -->
<div class="bg-white border-bottom sticky-top shadow-sm">
  <div class="container px-5">
    <nav class="d-flex gap-4 py-3 overflow-auto">
      {% for service in servicios_data.services %}
      <a href="#{{ service.slug }}" class="text-decoration-none text-dark fw-semibold small text-nowrap">{{ service.name }}</a>
      {% endfor %}
    </nav>
  </div>
</div>

<!-- Service sections -->
{% for service in servicios_data.services %}
<section class="py-6 {% if loop.index is even %}bg-light{% endif %}" id="{{ service.slug }}">
  <div class="container px-5">
    <div class="row gx-5 align-items-center">

      {% if loop.index is even %}
      <!-- Image right -->
      <div class="col-lg-7 mb-4 mb-lg-0">
        <div class="text-muted small text-uppercase fw-semibold mb-2">{{ service.tagline }}</div>
        <h2 class="fw-bold mb-1">{{ service.name }}</h2>
        <p class="text-muted mb-3">{{ service.subtitle }}</p>
        <p class="mb-4">{{ service.description }}</p>
        <ul class="list-unstyled">
          {% for feature in service.features %}
          <li class="mb-2 d-flex gap-2">
            <i class="bi bi-check-circle-fill text-dark flex-shrink-0 mt-1"></i>
            <span>{{ feature }}</span>
          </li>
          {% endfor %}
        </ul>
        <div class="d-flex gap-2 mt-3">
          <a href="{{ '/#contacto' | url }}" class="btn btn-dark">Solicitar información</a>
          <a href="{{ '/' | url }}" class="btn btn-outline-secondary"><i class="bi bi-house me-1"></i>Inicio</a>
        </div>
      </div>
      <div class="col-lg-5 text-center">
        <img src="{{ service.image | url }}" alt="{{ service.name }}"
          class="img-fluid rounded-3 shadow" style="max-height:320px;object-fit:contain;" />
      </div>

      {% else %}
      <!-- Image left -->
      <div class="col-lg-5 text-center mb-4 mb-lg-0">
        <img src="{{ service.image | url }}" alt="{{ service.name }}"
          class="img-fluid rounded-3 shadow" style="max-height:320px;object-fit:contain;" />
      </div>
      <div class="col-lg-7">
        <div class="text-muted small text-uppercase fw-semibold mb-2">{{ service.tagline }}</div>
        <h2 class="fw-bold mb-1">{{ service.name }}</h2>
        <p class="text-muted mb-3">{{ service.subtitle }}</p>
        <p class="mb-4">{{ service.description }}</p>
        <ul class="list-unstyled">
          {% for feature in service.features %}
          <li class="mb-2 d-flex gap-2">
            <i class="bi bi-check-circle-fill text-dark flex-shrink-0 mt-1"></i>
            <span>{{ feature }}</span>
          </li>
          {% endfor %}
        </ul>
        <div class="d-flex gap-2 mt-3">
          <a href="{{ '/#contacto' | url }}" class="btn btn-dark">Solicitar información</a>
          <a href="{{ '/' | url }}" class="btn btn-outline-secondary"><i class="bi bi-house me-1"></i>Inicio</a>
        </div>
      </div>
      {% endif %}

    </div>
  </div>
</section>
{% endfor %}

<!-- CTA -->
<section class="py-6 bg-dark text-white text-center">
  <div class="container px-5">
    <h3 class="fw-bold mb-2">¿Necesitas más información sobre nuestros servicios?</h3>
    <p class="text-white-50 mb-4">Contacta con nosotros y te asesoramos sin compromiso.</p>
    <a href="{{ '/#contacto' | url }}" class="btn btn-primary btn-lg px-5">Contacta con nosotros</a>
  </div>
</section>
